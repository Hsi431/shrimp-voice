# ===== 必填 =====
# Groq API key（STT 用，https://console.groq.com 免費申請）
GROQ_API_KEY=

# Picovoice AccessKey（喚醒詞引擎，https://console.picovoice.ai 免費申請）
PV_ACCESS_KEY=

# ===== 選填（不填用預設值）=====
# WebSocket 連線驗證 token；設了之後 client 沒帶 ?token= 一律 401。建議：openssl rand -hex 16
#SHRIMP_WS_TOKEN=

# 喚醒詞靈敏度 0~1，越高越靈敏但誤喚醒越多（預設 0.6）
#WAKE_SENSITIVITY=0.6

# 喚醒詞 .ppn 與中文聲學模型路徑（預設找 server/ 目錄下的 wake_word.ppn 和 porcupine_params_zh.pv）
#KEYWORD_PATH=
#PORCUPINE_MODEL_PATH=

# OpenClaw 相關
#OPENCLAW_PATH=~/.npm-global/bin/openclaw
#AGENT_ID=main
#DEFAULT_SESSION_ID=
#SESSION_ID_FILE=/tmp/shrimp_current_session

# TTS 聲音（edge-tts，列表：edge-tts --list-voices）與喚醒回應詞
#TTS_VOICE=zh-TW-HsiaoChenNeural
#WAKE_REPLY=在！

# 伺服器埠與自簽憑證路徑（預設 server/ 目錄下的 cert.pem / key.pem）
#PORT=8443
#SSL_CERT=
#SSL_KEY=

#NODE_BIN=/usr/bin/node
